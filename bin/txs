#!/usr/bin/env bash
#
# txs - Manage tmux sessions from predefined project directories
#
# Usage:
#   txs                          Interactive picker
#   txs attach [name] [worktree] Attach to a session / open a worktree
#   txs kill [name]              Kill a session (interactive picker when no arg)
#   txs ls [sessions|projects|worktrees]
#                                List sessions, projects, and/or worktrees
#   txs add [path]               Add a directory to the config
#   txs remove <name>            Remove a project from the config
#   txs clone-bare <url> [name]  Clone repo as bare + worktree setup
#   txs config                   Open config in $EDITOR
#   txs help                     Show help
#   txs version                  Show version
#
# shellcheck source-path=SCRIPTDIR

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve and source library files
# ---------------------------------------------------------------------------

TXS_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)/lib/txs"

# shellcheck source=../lib/log.sh
source "${TXS_ROOT}/log.sh"
# shellcheck source=../lib/config.sh
source "${TXS_ROOT}/config.sh"
# shellcheck source=../lib/tmux.sh
source "${TXS_ROOT}/tmux.sh"
# shellcheck source=../lib/git.sh
source "${TXS_ROOT}/git.sh"
# shellcheck source=../lib/commands.sh
source "${TXS_ROOT}/commands.sh"
# shellcheck source=../lib/ui.sh
source "${TXS_ROOT}/ui.sh"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

require_arg() {
	local value="$1" label="$2" usage="$3"
	if [[ -z $value ]]; then
		error "Missing $label."
		printf '%s\n' "Usage: $usage" >&2
		return 1
	fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
	local cmd="${1:-}"

	case "$cmd" in
	ls | list)
		cmd_ls "${2:-}"
		;;
	sessions)
		cmd_ls "sessions"
		;;
	projects)
		cmd_ls "projects"
		;;
	attach | create | worktrees)
		cmd_attach "${2:-}" "${3:-}"
		;;
	kill)
		cmd_kill "${2:-}"
		;;
	add)
		cmd_add "${2:-.}"
		;;
	remove)
		require_arg "${2:-}" "project name" "txs remove <project-name>" || return 1
		cmd_remove "$2"
		;;
	clone-bare)
		require_arg "${2:-}" "repository URL" "txs clone-bare <repo-url> [folder-name]" || return 1
		cmd_clone_bare "$2" "${3:-}"
		;;
	config)
		cmd_config "${2:-}"
		;;
	help | --help | -h)
		cmd_help
		;;
	version | --version | -v)
		printf '%s\n' "txs ${TXS_VERSION}"
		;;
	"")
		cmd_interactive
		;;
	*)
		error "Unknown command '${cmd}'."
		printf '\n'
		cmd_help
		return 1
		;;
	esac
}

main "$@"
